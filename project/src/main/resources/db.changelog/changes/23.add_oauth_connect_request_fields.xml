<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd">

    <changeSet id="23" author="tijana">
        <addColumn tableName="oauth_connect_requests">
            <column name="consumed" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="completed" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="failure_reason" type="VARCHAR(500)"/>
        </addColumn>

        <rollback>
            <dropColumn tableName="oauth_connect_requests" columnName="consumed"/>
            <dropColumn tableName="oauth_connect_requests" columnName="completed"/>
            <dropColumn tableName="oauth_connect_requests" columnName="failure_reason"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
