<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
          http://www.liquibase.org/xml/ns/dbchangelog
          http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd">

    <changeSet id="15.1" author="tijana">
        <createTable tableName="insight_snapshot">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>

            <column name="provider" type="VARCHAR(32)">
                <constraints nullable="false"/>
            </column>

            <column name="ad_account_id" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>

            <column name="object_type" type="VARCHAR(16)">
                <constraints nullable="false"/>
            </column>

            <column name="object_external_id" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>

            <column name="date_start" type="DATE">
                <constraints nullable="false"/>
            </column>

            <column name="date_stop" type="DATE">
                <constraints nullable="false"/>
            </column>

            <column name="time_increment" type="INT">
                <constraints nullable="false"/>
            </column>

            <!-- For future-proofing: store breakdowns config and the raw response -->
            <column name="breakdowns_json" type="JSONB"/>
            <column name="raw_json" type="JSONB"/>

            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="insight_snapshot" indexName="idx_ins_snapshot_user_obj_range">
            <column name="user_id"/>
            <column name="provider"/>
            <column name="ad_account_id"/>
            <column name="object_type"/>
            <column name="object_external_id"/>
            <column name="date_start"/>
            <column name="date_stop"/>
        </createIndex>

        <!-- dedup constraint: same query params should not create duplicates -->
        <addUniqueConstraint
                tableName="insight_snapshot"
                constraintName="uk_ins_snapshot_unique"
                columnNames="user_id,provider,ad_account_id,object_type,object_external_id,date_start,date_stop,time_increment"/>
    </changeSet>

    <changeSet id="15.2" author="tijana">
        <createTable tableName="insight_metric">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="snapshot_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>

            <column name="name" type="VARCHAR(128)">
                <constraints nullable="false"/>
            </column>

            <column name="value_number" type="NUMERIC(28,6)"/>
            <column name="value_text" type="TEXT"/>

            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="insight_metric"
                baseColumnNames="snapshot_id"
                referencedTableName="insight_snapshot"
                referencedColumnNames="id"
                constraintName="fk_ins_metric_snapshot"
                onDelete="CASCADE"/>

        <createIndex tableName="insight_metric" indexName="idx_ins_metric_snapshot">
            <column name="snapshot_id"/>
        </createIndex>

        <createIndex tableName="insight_metric" indexName="idx_ins_metric_name">
            <column name="name"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>